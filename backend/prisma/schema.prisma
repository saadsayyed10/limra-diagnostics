generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model clinic {
  id            String          @id @default(uuid())
  clerkId       String          @unique
  name          String
  email         String          @unique
  profilePicUrl String?
  status        Boolean         @default(false)
  type          ClinicUserType?
  createdAt     DateTime        @default(now())
}

model patients {
  id           String      @id @default(uuid())
  name         String
  age          Int
  phone        String      @unique
  patientType  PatientType
  address      Json
  husband      String?
  livingBoys   String[]
  livingGirls  String[]
  aadharNumber String?
  createdAt    DateTime    @default(now())

  bills bills[]
}

model bills {
  id          String   @id @default(uuid())
  scanType    ScanType
  totalAmount Float
  dueAmount   Float?
  concession  Float?
  docxUrl     String
  createdAt   DateTime @default(now())

  patientId String?
  patients  patients? @relation(fields: [patientId], references: [id])
}

enum ScanType {
  ABDOMEN
  PELVIS
  CHEST
  OBS
}

enum ClinicUserType {
  DOCTOR
  RECEPTIONIST
}

enum PatientType {
  OBS
  REGULAR
}
